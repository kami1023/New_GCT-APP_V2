rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "minatoweeb123@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidProduct(data) {
      return hasRequiredFields(['id', 'name', 'stock_level', 'price']) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.stock_level is int &&
             data.price is number;
    }

    function isValidStockLog(data) {
      return hasRequiredFields(['product_id', 'change', 'reason', 'timestamp']) &&
             data.product_id is string &&
             data.change is int &&
             data.reason is string &&
             data.timestamp is string;
    }

    function isValidInvoice(data) {
      return hasRequiredFields(['invoice_no', 'date', 'grand_total']) &&
             data.invoice_no is string &&
             data.date is string &&
             data.grand_total is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /purchasers/{purchaserId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /invoice_items/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /stock_logs/{logId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
